STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-v2

# Meta / Instagram bot
# Long-lived IG User access token (App Dashboard → Use cases → Generate token)
IG_PAGE_ACCESS_TOKEN=
# IG Business Account ID (shown next to the account in the token generator)
IG_BUSINESS_ACCOUNT_ID=
# App Secret (App Dashboard → Settings → Basic) — used for webhook signature verification
META_APP_SECRET=
# Random string shared with Meta during webhook configuration
IG_WEBHOOK_VERIFY_TOKEN=
# Optional — Graph API version to call (defaults to v21.0)
META_GRAPH_VERSION=v21.0
# Optional — trigger word in comments that makes the bot auto-reply
IG_COMMENT_TRIGGER=
